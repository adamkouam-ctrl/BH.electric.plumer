    "mainEntity": [
      {
        "@type": "Question",
        "name": "Operate in tutto il nord Italia?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Sì, operiamo in tutte le principali città del nord Italia incluse Milano, Torino, Bergamo, Brescia, Verona, Padova, Venezia, Bologna, Genova e molte altre."
